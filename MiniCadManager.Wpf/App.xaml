<Application x:Class="MiniCadManager.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource PrimaryAccent}"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentForeground}"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Background" Value="{DynamicResource DisabledBackground}" />
                        <Setter Property="Foreground" Value="{DynamicResource DisabledForeground}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            
            <Style TargetType="Label">
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            </Style>

            <Style TargetType="{x:Type DataGridColumnHeader}">
                <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
                <Setter Property="TextElement.Foreground" Value="{DynamicResource InputForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="5"/>
            </Style>
            
            <Style TargetType="{x:Type DataGridRow}">
                <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
            </Style>
            
            <Style TargetType="{x:Type DataGridCell}">
                <Setter Property="Foreground" Value="{DynamicResource TextForeground}"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>
