<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="PanelBackground" Color="White"/>
    <SolidColorBrush x:Key="TextForeground" Color="Black"/>
    <SolidColorBrush x:Key="BorderColor" Color="#DDDDDD"/>
    <SolidColorBrush x:Key="PrimaryAccent" Color="#007ACC"/>
    <SolidColorBrush x:Key="PrimaryAccentForeground" Color="White"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#E6E6E6"/>
    <SolidColorBrush x:Key="DisabledForeground" Color="#A6A6A6"/>
    <SolidColorBrush x:Key="InputBackground" Color="White"/>
    <SolidColorBrush x:Key="InputForeground" Color="Black"/>
</ResourceDictionary>
