<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackground" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextForeground" Color="#111827"/>
    <SolidColorBrush x:Key="BorderColor" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="PrimaryAccent" Color="#3B82F6"/>
    <SolidColorBrush x:Key="PrimaryAccentForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="DisabledForeground" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="InputBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputForeground" Color="#111827"/>
</ResourceDictionary>
