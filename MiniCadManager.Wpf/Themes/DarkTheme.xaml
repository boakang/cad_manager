<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelBackground" Color="#252526"/>
    <SolidColorBrush x:Key="TextForeground" Color="#D4D4D4"/>
    <SolidColorBrush x:Key="BorderColor" Color="#3F3F46"/>
    <SolidColorBrush x:Key="PrimaryAccent" Color="#007ACC"/>
    <SolidColorBrush x:Key="PrimaryAccentForeground" Color="White"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#333333"/>
    <SolidColorBrush x:Key="DisabledForeground" Color="#777777"/>
    <SolidColorBrush x:Key="InputBackground" Color="White"/>
    <SolidColorBrush x:Key="InputForeground" Color="Black"/>
</ResourceDictionary>
